# 認証情報(本番では必ず変更すること)
ADMIN_USER=admin
ADMIN_PASSWORD=su-admin
MEMBER_USER=member
MEMBER_PASSWORD=su-member

# 年度・データ置き場(省略時: 2026 / backend/data)
# FISCAL_YEAR=2026
# DATA_DIR=/path/to/data

# GitHub永続化(要件定義書 案A・省略可)
# データ用プライベートリポジトリを作り、Contents権限(Read/Write)付きの
# Fine-grained personal access token を設定すると、書き込みのたびに
# リポジトリの data/ 配下へ自動プッシュされる。
# GITHUB_TOKEN=github_pat_xxx
# GITHUB_DATA_REPO=your-account/su-finance-data
# GITHUB_DATA_BRANCH=main
